# {{HOST_DISPLAY}}-to-IM Bridge Configuration
# Copy to ~/.{{SKILL_COMMAND}}/config.env and edit

# Runtime backend: {{RUNTIME_OPTIONS_PLAIN}}
{{CONFIG_RUNTIME_NOTES}}
CTI_RUNTIME={{DEFAULT_RUNTIME}}

# Enabled channels (comma-separated: telegram,discord,feishu)
CTI_ENABLED_CHANNELS=telegram

# Default working directory for bridge sessions
CTI_DEFAULT_WORKDIR=/path/to/your/project

# Default model (optional — inherits from runtime's own default if not set)
# CTI_DEFAULT_MODEL=

# Default mode (code, plan, ask)
CTI_DEFAULT_MODE=code

# ── Codex auth (optional — only if not using `codex auth login`) ──
# Priority: CTI_CODEX_API_KEY > CODEX_API_KEY > OPENAI_API_KEY
# CTI_CODEX_API_KEY=
# CTI_CODEX_BASE_URL=
# Allow Codex to run outside trusted git repos when bridge sessions start from
# a general workspace such as /Users/eli. Set to false to require trusted repos.
CTI_CODEX_SKIP_GIT_REPO_CHECK=true

# ── Telegram ──
CTI_TG_BOT_TOKEN=your-telegram-bot-token
# Chat ID for authorization (at least one of CHAT_ID or ALLOWED_USERS is required)
# Get it: send a message to the bot, then visit https://api.telegram.org/botYOUR_TOKEN/getUpdates
CTI_TG_CHAT_ID=your-chat-id
# CTI_TG_ALLOWED_USERS=user_id_1,user_id_2

# ── Discord ──
# CTI_DISCORD_BOT_TOKEN=your-discord-bot-token
# CTI_DISCORD_ALLOWED_USERS=user_id_1,user_id_2
# CTI_DISCORD_ALLOWED_CHANNELS=channel_id_1
# CTI_DISCORD_ALLOWED_GUILDS=guild_id_1

# ── Feishu / Lark ──
# CTI_FEISHU_APP_ID=your-app-id
# CTI_FEISHU_APP_SECRET=your-app-secret
# CTI_FEISHU_DOMAIN=https://open.feishu.cn
# CTI_FEISHU_ALLOWED_USERS=user_id_1,user_id_2
# Transcribe Feishu audio messages before they reach the runtime.
# Default: true. Set to false to keep audio as raw attachments only.
# CTI_FEISHU_AUDIO_TRANSCRIBE=true
# Optional explicit audio transcoder path or command name.
# Auto-detect order: ffmpeg -> /usr/bin/afconvert
# CTI_AUDIO_TRANSCODER=/opt/homebrew/bin/ffmpeg
# Optional ElevenLabs voice reply. Only used when the user explicitly asks
# for a voice/audio reply. Keep this API key local only; never paste it into
# IM chats. config.env is written with chmod 600, and FileVault is recommended.
# CTI_ELEVENLABS_API_KEY=your-elevenlabs-api-key
# CTI_ELEVENLABS_VOICE_ID=your-elevenlabs-voice-id
# CTI_ELEVENLABS_MODEL_ID=eleven_multilingual_v2
# Optional OpenAI Whisper fallback for inbound audio transcription.
# If Feishu STT is rate-limited or unavailable, bridge can send the audio to
# OpenAI's transcription API instead. Only enable this if you are comfortable
# with the audio leaving your device for OpenAI processing.
# CTI_OPENAI_API_KEY=your-openai-api-key

# ── Permission ──
# Auto-approve all tool permission requests without user confirmation.
# Useful for channels that lack interactive permission UI (e.g. Feishu
# WebSocket long-connection mode, where there is no HTTP webhook to
# render clickable approve/deny buttons).
# ⚠️  Only enable this in trusted, access-controlled environments.
# CTI_AUTO_APPROVE=true
