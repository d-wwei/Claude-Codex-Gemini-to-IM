{
  "name": "claude-to-im-skill",
  "version": "0.1.0",
  "description": "Claude Code Skill: Bridge IM platforms (Telegram, Discord, Feishu, QQ) to Claude Code sessions",
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/apply-bridge-patches.mjs",
    "build": "node scripts/apply-bridge-patches.mjs && node scripts/build.js",
    "render:host": "node scripts/render-host-templates.mjs",
    "typecheck": "node scripts/apply-bridge-patches.mjs && tsc --noEmit",
    "dev": "tsx src/main.ts",
    "test": "node scripts/apply-bridge-patches.mjs && CTI_HOME=$(mktemp -d) node --test --test-concurrency=1 --import tsx --test-timeout=15000 src/__tests__/*.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.62",
    "claude-to-im": "github:op7418/claude-to-im"
  },
  "optionalDependencies": {
    "@openai/codex-sdk": "^0.110.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "esbuild": "^0.25.0",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20"
  }
}
